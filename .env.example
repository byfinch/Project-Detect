# AdsPower Local API
# Base URL of the AdsPower local automation API (default when AdsPower runs locally)
ADSPOWER_BASE_URL=http://local.adspower.net:50325
# API key from AdsPower -> Settings -> API (required by recent AdsPower versions)
ADSPOWER_API_KEY=

# AdsPower profile IDs to drive the scans.
# Device emulation over CDP is unreliable, so use ONE profile per device:
#  - PROFILE_DESKTOP: a Windows/desktop-fingerprint profile with a Turkey proxy
#  - PROFILE_MOBILE:  an Android/iOS-fingerprint profile (mobile UA + viewport) with a Turkey proxy
PROFILE_DESKTOP=
PROFILE_MOBILE=

# Captcha solvers (optional) — Google /sorry reCAPTCHA wall
# provider=auto tries CapSolver first (faster), then 2captcha
TWOCAPTCHA_API_KEY=
CAPSOLVER_API_KEY=

# Output directory for the SQLite DB, screenshots and reports
OUTPUT_DIR=./data
